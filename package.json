{
  "name": "lumos",
  "version": "1.0.0",
  "private": true,
  "description": "Lumos — an AI studio that turns plain-English prompts into production-ready React + Tailwind components, rendered live in a secure sandbox. Multi-provider (Groq, OpenAI, Anthropic, Gemini, local Ollama).",
  "keywords": [
    "ai",
    "react",
    "nextjs",
    "tailwindcss",
    "code-generation",
    "component-generator",
    "vercel-ai-sdk",
    "groq",
    "ollama",
    "sandpack"
  ],
  "author": "Shahriar Ahmed",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.23",
    "@ai-sdk/google": "^3.0.13",
    "@ai-sdk/groq": "^3.0.15",
    "@ai-sdk/openai": "^3.0.19",
    "@clerk/nextjs": "^6.36.10",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "ai": "^6.0.50",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.563.0",
    "next": "^16.1.5",
    "pg": "^8.17.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "prisma": "^7.3.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
