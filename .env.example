# ===========================================
# Lumos — Environment Variables
# Copy this file to .env.local and fill in your own keys.
# NEVER commit real secrets. This file must contain placeholders only.
# ===========================================

# -------------------------------------------
# AI PROVIDERS (add keys for the providers you want to enable)
# -------------------------------------------

# Groq (FREE tier — recommended default) → https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI (paid) → https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (paid) → https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini (FREE tier available) → https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Local Ollama (FREE — runs on your machine, no key required)
# Install: https://ollama.com  •  Pull model: ollama pull gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434

# -------------------------------------------
# DEFAULT PROVIDER & MODEL SETTINGS
# -------------------------------------------

# Default provider: 'groq' | 'openai' | 'anthropic' | 'google' | 'local'
DEFAULT_AI_PROVIDER=groq

GROQ_MODEL_LARGE=llama-3.3-70b-versatile
GROQ_MODEL_SMALL=llama-3.1-8b-instant
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_MODEL=gemini-2.5-flash-lite
LOCAL_MODEL=gemma3:4b

# -------------------------------------------
# DATABASE (PostgreSQL)
# -------------------------------------------
# Neon (FREE): https://neon.tech  •  Supabase: https://supabase.com
# Local: postgresql://user:password@localhost:5432/lumos
DATABASE_URL=

# -------------------------------------------
# AUTH (Clerk) — optional. If unset, the app runs in open/anonymous mode.
# https://dashboard.clerk.com
# -------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# -------------------------------------------
# IMAGERY (build-time only — never exposed to the browser)
# Used by the marketing pages to fetch cinematic hero photography.
# Get a key: https://unsplash.com/oauth/applications
# -------------------------------------------
UNSPLASH_ACCESS_KEY=
